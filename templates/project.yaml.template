# ═══════════════════════════════════════════════════════════
# Agent Hub — 프로젝트 설정 (project.yaml)
# projects/{프로젝트명}/project.yaml 에 위치합니다.
# 프로젝트 생성 시 한 번 작성하고, 이후 큰 변경이 없는 항목들.
# 시스템 기본값(config.yaml)을 override하고 싶은 항목만 작성하면 됩니다.
# ═══════════════════════════════════════════════════════════

project:
  name: "my-project"              # 프로젝트명 (디렉토리명과 일치)
  description: |
    이 프로젝트가 무엇인지, 어떤 기술 스택을 사용하는지 자유롭게 기술하세요.
    예) TypeScript + Next.js 웹 서비스. Tailwind CSS 사용. PostgreSQL + Prisma ORM.
    예) Python 기반 데이터 파이프라인. Kafka, Flink 사용.
  default_branch: "main"

# ─── 코드베이스 ───
codebase:
  path: "/home/user/projects/my-project"    # 절대경로 필수
  service_bind_address: "0.0.0.0"
  service_port: 3000

# ─── Git ───
# enabled: false면 branch/commit/PR 등 모든 git 작업을 건너뜀
git:
  enabled: true
  provider: "github"              # github | bitbucket | gitlab (현재 github만 구현)
  remote: "origin"
  author_name: "agent-bot"
  author_email: "agent@example.com"
  auto_merge: false               # true: PR 생성 후 자동 머지 / false: PR만 생성 (waiting_for_human_pr_approve)
  pr_target_branch: "develop"     # PR의 base branch
  auth_token: ""                  # provider 인증 토큰 (GitHub PAT 등)

# ─── 테스트 ───
# 각 항목의 enabled 값은 project_state.json에서 동적으로 변경 가능
testing:
  unit_test:
    enabled: false
    available_suites: []
    #   - name: "model"
    #     command: "pytest tests/models/"
    #     description: "ORM 모델 CRUD 테스트"
    #   - name: "api"
    #     command: "pytest tests/api/"
    #     description: "API 엔드포인트 테스트"
    default_suites: []

  e2e_test:
    enabled: false
    tool: "playwright"
    test_accounts: []
    #   - email: "test@example.com"
    #     password: "password123"
    #     role: "user"

  integration_test:
    enabled: false
    suites: []
    include_e2e: false    # e2e_test.enabled=false면 이 값도 무시됨

# ─── 안전 제한 override (선택적) ───
# config.yaml의 default_limits를 프로젝트 레벨에서 덮어쓸 수 있습니다.
# 필요한 항목만 작성하면 나머지는 시스템 기본값을 따릅니다.
# limits:
#   max_subtask_count: 5            # Planner가 만들 수 있는 최대 subtask 수
#   max_retry_per_subtask: 3        # subtask당 Coder 재시도 횟수
#   max_replan_count: 2             # task당 replan 허용 횟수 (초과 시 escalation)
#   max_total_agent_invocations: 30 # task당 전체 agent 호출 총횟수
#   max_task_duration_hours: 4      # task 시작 후 최대 허용 시간

# ─── Claude 모델 override (선택적) ───
# config.yaml의 claude 설정을 프로젝트별로 바꿀 수 있습니다.
# claude:
#   planner_model: "opus"
#   coder_model: "sonnet"
#   reviewer_model: "opus"
#   setup_model: "sonnet"
#   unit_tester_model: "sonnet"
#   e2e_tester_model: "sonnet"
#   reporter_model: "sonnet"
#   max_turns_per_session: 50

# ─── 사람 개입 정책 override (선택적) ───
# config.yaml의 default_human_review_policy를 프로젝트별로 바꿀 수 있습니다.
# human_review_policy:
#   review_plan: true               # Planner 결과를 사람이 확인 후 진행
#   review_replan: true             # replan 발생 시 사람이 확인 후 진행
#   review_before_merge: false      # 머지 전 사람 확인 (auto_merge=false면 PR로 대체)
#   auto_approve_timeout_hours: 24  # 사람 응답 없으면 자동 승인까지 대기 시간

# ─── task 큐 override (선택적) ───
# config.yaml의 default_task_queue를 프로젝트별로 바꿀 수 있습니다.
# task_queue:
#   wait_for_prev_task_done: true    # false면 이전 task 미완료여도 다음 task 실행

# ─── 알림 override (선택적) ───
# config.yaml의 notification 기본값을 프로젝트별로 바꿀 수 있습니다.
# notification:
#   channel: "cli"                  # cli | slack | telegram (Phase 1.4+)
#   slack_webhook_url: ""
#   telegram_chat_id: ""
