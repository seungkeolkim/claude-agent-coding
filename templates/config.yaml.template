# ═══════════════════════════════════════════════════════════
# Agent Hub — 시스템 설정 (config.yaml)
# 시스템 전체에 적용되는 장비 정보, Claude 모델, 안전 제한 기본값.
# 프로젝트별 설정은 projects/{name}/project.yaml에 작성합니다.
# ═══════════════════════════════════════════════════════════

# ─── 장비 / 인프라 ───
machines:
  executor:
    ssh_key: "~/.ssh/id_rsa"
    github_token: ""                # GitHub API/PR 자동화에 필요 시 설정 (ghp_xxxxx)
    git_credential_helper: "store"
    service_bind_address: "0.0.0.0"
  tester:
    browser: "chromium"
    viewport:
      width: 1280
      height: 720
    ssh_reconnect_interval_seconds: 5

# ─── Claude Code ───
claude:
  planner_model: "opus"
  coder_model: "sonnet"
  reviewer_model: "opus"
  setup_model: "sonnet"
  unit_tester_model: "sonnet"
  e2e_tester_model: "sonnet"
  reporter_model: "sonnet"
  max_turns_per_session: 50

  # Usage 기반 실행 제어
  # 5시간 세션 사용량이 이 threshold 이상이면 해당 레벨의 실행을 대기
  usage_thresholds:
    new_task: 0.70            # 새 task 시작 허용 기준
    new_subtask: 0.80         # 새 subtask 시작 허용 기준
    new_agent_stage: 0.90     # pipeline 내 다음 agent 호출 허용 기준
  usage_check_interval_seconds: 60   # threshold 초과 시 재확인 주기

# ─── 안전 제한 기본값 (프로젝트별 override 가능) ───
default_limits:
  max_subtask_count: 5
  max_retry_per_subtask: 3
  max_replan_count: 2
  max_total_agent_invocations: 30
  max_task_duration_hours: 4

# ─── 사람 개입 정책 기본값 (프로젝트별 override 가능) ───
default_human_review_policy:
  review_plan: true
  review_replan: true
  review_before_merge: false
  auto_approve_timeout_hours: 24

# ─── task 큐 기본값 (프로젝트별 override 가능) ───
default_task_queue:
  wait_for_prev_task_done: true    # true: 이전 task 완료 전까지 다음 task spawn 안 함

# ─── 로깅 ───
logging:
  level: "info"
  archive_completed_tasks: true
  keep_session_logs: true

# ─── 알림 기본값 (프로젝트별 override 가능) ───
notification:
  channel: "cli"      # "cli" | 향후: "slack" | "telegram"
  # 알림 대상 이벤트 (전부 true가 기본)
  events:
    task_completed: true
    task_failed: true
    pr_created: true
    pr_merged: true
    pr_merge_failed: true
    plan_review_requested: true
    replan_review_requested: true
    escalation: true
  # 재알림 설정 (waiting_for_human_plan_confirm 상태에서 응답 없을 때)
  re_notification_interval_hours: 4   # 0이면 재알림 비활성화

# ─── Chatbot 설정 ───
chatbot:
  model: "sonnet"               # chatbot 해석용 모델 (sonnet 권장)
  confirmation_mode: "smart"    # "always_confirm" | "never_confirm" | "smart"
  # smart 모드 동작:
  #   확인 필요: submit, approve, reject, cancel, config (고위험)
  #   즉시 실행: feedback, mark_notification_read, pause, resume (저위험)
  #   조회성 action(list, get_task, pending, status, notifications)은 항상 즉시 실행

# ─── 웹 콘솔 설정 ───
web:
  port: 9880                      # 웹 콘솔 포트
  db_path: "data/ai_agent_coding.db"  # SQLite DB 경로 (상대경로는 agent_hub_root 기준)

# ─── Telegram 연동 (Phase 2.3) ───
# 슈퍼그룹 + Forum Topics 기반. 프로젝트당 1개 topic이 자동 생성되고,
# 해당 topic에서 자연어/슬래시 명령으로 task 제출·승인·조회를 수행한다.
# Bootstrap 순서는 docs_for_claude/017-handoff-telegram-integration.md §6 참고.
telegram:
  enabled: false                  # true일 때만 run_system.sh start 시 bridge가 기동
  bot_token: ""                   # BotFather에서 발급 (빈 값이면 자동 disabled). 로그 출력 금지
  hub_chat_id: 0                  # /bind_hub 명령으로 자동 기록됨 (수동 편집 권장 안 함)
  allowed_user_ids: []            # 이 목록 외 user의 메시지는 무시 (빈 배열이면 전체 거부)
  bind_secret: ""                 # /bind_hub <secret> 검증용. bind 성공 시 소비(빈 문자열로 rewrite)
  long_polling_timeout_seconds: 30   # getUpdates long polling timeout
  reconciliation_interval_hours: 24  # orphan topic 탐지 주기 (bridge 기동 시 1회 + 이 주기마다)
  send_interval_seconds: 0.05     # outbound rate limit (Bot API 30msg/sec/그룹 대응 token bucket)
