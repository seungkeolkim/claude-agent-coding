digraph TaskLifecycle {
    // 전체 설정
    rankdir=TB;
    bgcolor="white";
    fontname="Segoe UI, Arial, sans-serif";
    pad=0.3;
    nodesep=0.35;
    ranksep=0.55;

    // 노드 기본 스타일
    node [
        fontname="Segoe UI, Arial, sans-serif"
        fontsize=16
        style="filled,rounded"
        shape=box
        penwidth=2
        margin="0.15,0.08"
        height=0.5
    ];

    // 엣지 기본 스타일
    edge [
        fontname="Segoe UI, Arial, sans-serif"
        fontsize=13
        fontcolor="#333333"
        color="#666688"
        penwidth=1.5
        arrowsize=1.0
    ];

    // ─── 노드 정의 ───

    // 시작/종료 마커
    start [label="" shape=circle width=0.4 fillcolor="#0077aa" color="#0077aa" penwidth=2.5];
    end [label="" shape=doublecircle width=0.35 fillcolor="#555577" color="#888888" penwidth=2.5];

    // 초기 상태
    submitted [
        label="submitted\n(task 생성)"
        fillcolor="#2196F3"
        fontcolor="white"
        color="#1565C0"
    ];

    // 계획 상태
    planned [
        label="planned\n(실행 대기)"
        fillcolor="#00BCD4"
        fontcolor="white"
        color="#00838F"
    ];

    // 대기 상태
    waiting_for_human_plan_confirm [
        label="waiting_for_human_plan_confirm\n(승인 대기)"
        fillcolor="#FF5722"
        fontcolor="white"
        color="#BF360C"
    ];

    needs_replan [
        label="needs_replan\n(재계획 필요)"
        fillcolor="#E91E63"
        fontcolor="white"
        color="#880E4F"
    ];

    // 실행 상태
    in_progress [
        label="in_progress\n(subtask 실행 중)"
        fillcolor="#FF9800"
        fontcolor="black"
        color="#E65100"
        penwidth=3
    ];

    // 리뷰 상태
    waiting_for_human_pr_approve [
        label="waiting_for_human_pr_approve\n(PR 머지 대기)"
        fillcolor="#FF5722"
        fontcolor="white"
        color="#BF360C"
    ];

    // 종료 상태
    completed [
        label="completed"
        fillcolor="#4CAF50"
        fontcolor="white"
        color="#2E7D32"
        penwidth=2.5
    ];

    failed [
        label="failed"
        fillcolor="#F44336"
        fontcolor="white"
        color="#B71C1C"
        penwidth=2.5
    ];

    cancelled [
        label="cancelled"
        fillcolor="#888888"
        fontcolor="white"
        color="#555555"
        penwidth=2.5
    ];

    escalated [
        label="escalated\n(수동 개입 필요)"
        fillcolor="#9C27B0"
        fontcolor="white"
        color="#6A1B9A"
        penwidth=2.5
    ];

    // resubmit 안내
    resubmit_note [
        label="resubmit →\n새 task 생성"
        shape=note
        fillcolor="#e8e8f0"
        fontcolor="#0077aa"
        color="#666688"
        fontsize=13
    ];

    // ─── 전이 ───

    // 시작
    start -> submitted [label="submit" color="#0077aa" fontcolor="#0077aa"];

    // submitted →
    submitted -> planned [label="Planner 성공\n(review=false)"];
    submitted -> waiting_for_human_plan_confirm [label="Planner 성공\n(review=true)"];
    submitted -> failed [label="Planner 실패" color="#F44336" fontcolor="#B71C1C"];
    submitted -> cancelled [label="cancel" style=dashed color="#888888" fontcolor="#555555"];

    // waiting_for_human_plan_confirm →
    waiting_for_human_plan_confirm -> planned [label="approve /\ntimeout 자동승인" color="#4CAF50" fontcolor="#2E7D32"];
    waiting_for_human_plan_confirm -> needs_replan [label="reject (modify)" color="#E91E63" fontcolor="#880E4F"];
    waiting_for_human_plan_confirm -> cancelled [label="cancel" style=dashed color="#888888" fontcolor="#555555"];

    // needs_replan →
    needs_replan -> waiting_for_human_plan_confirm [label="Replanner 성공\n(review=true)"];
    needs_replan -> planned [label="Replanner 성공\n(review=false)"];
    needs_replan -> failed [label="Replanner 실패" color="#F44336" fontcolor="#B71C1C"];

    // planned →
    planned -> in_progress [label="git branch →\nsubtask loop" color="#FF9800" fontcolor="#E65100"];
    planned -> failed [label="branch 생성 실패" color="#F44336" fontcolor="#B71C1C"];

    // in_progress → (self-loop)
    in_progress -> in_progress [
        label="subtask 완료 → 다음\nReviewer 거절 → Coder 재시도"
        color="#FF9800"
        fontcolor="#E65100"
        style=dashed
    ];

    // in_progress → 다른 상태
    in_progress -> completed [label="모든 subtask 완료\n+ auto_merge=true" color="#4CAF50" fontcolor="#2E7D32"];
    in_progress -> waiting_for_human_pr_approve [label="모든 subtask 완료\n+ auto_merge=false"];
    in_progress -> needs_replan [label="Reporter:\nreplan 요청" color="#E91E63" fontcolor="#880E4F"];
    in_progress -> escalated [label="한도 초과\n에스컬레이션" color="#9C27B0" fontcolor="#6A1B9A"];
    in_progress -> failed [label="Agent/git/PR\n실패" color="#F44336" fontcolor="#B71C1C"];
    in_progress -> cancelled [label="cancel" style=dashed color="#888888" fontcolor="#555555"];

    // waiting_for_human_pr_approve →
    waiting_for_human_pr_approve -> completed [label="PR 수동 머지\n(외부)" color="#4CAF50" fontcolor="#2E7D32" style=dashed];
    waiting_for_human_pr_approve -> failed [label="PR 거부/닫힘\n(외부)" color="#F44336" fontcolor="#B71C1C" style=dashed];

    // 종료 → end
    completed -> end [color="#4CAF50"];
    failed -> end [color="#F44336"];
    cancelled -> end [color="#888888"];
    escalated -> end [color="#9C27B0"];

    // resubmit
    failed -> resubmit_note [style=dotted color="#0077aa" arrowhead=none];
    cancelled -> resubmit_note [style=dotted color="#0077aa" arrowhead=none];
    resubmit_note -> submitted [style=dotted color="#0077aa" label="새 task"];

    // ─── 레이아웃 힌트 ───
    { rank=same; submitted }
    { rank=same; waiting_for_human_plan_confirm; planned; needs_replan }
    { rank=same; in_progress }
    { rank=same; waiting_for_human_pr_approve }
    { rank=same; completed; failed; cancelled; escalated }

    // 타이틀
    labelloc=t;
    label="Task Lifecycle — Finite State Machine";
    fontsize=22;
    fontcolor="#0055aa";
}
